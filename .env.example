# WebSocket-to-TCP proxy URL for Lightning peer connections.
# Optional — defaults to wss://p.mutinynet.com if unset.
VITE_WS_PROXY_URL=wss://p.mutinynet.com

# VSS (Versioned Storage Service) URL for encrypted remote state backup.
# Optional — defaults to /__vss_proxy/vss if unset.
# In local dev, the Vite proxy forwards /__vss_proxy to VSS_PROXY_TARGET.
# On Vercel, a rewrite rule in vercel.json handles the same path.
VITE_VSS_URL=/__vss_proxy/vss
